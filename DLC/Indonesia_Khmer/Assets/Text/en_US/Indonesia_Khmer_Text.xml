		<!-- Unit Abilities  -->
		<Row Tag="LOC_ABILITY_MARTYR_DESCRIPTION">
			<Text>Relik [ICON_GreatWork_Relic] dibuat jika unit ini mati dalam Pertempuran Teologis.</Text>
		</Row>
		<Row Tag="LOC_ABILITY_JONG_DESCRIPTION">
			<Text>+5 [ICON_Strength] Bonus Kekuatan Tempur saat dalam formasi.[NEWLINE][ICON_Bullet]Unit dalam formasi mewarisi gerakan Jong.</Text>
		</Row>
		<Row Tag="LOC_ABILITY_GITARJA_RELIGIOUS_NO_EMBARK_DISEMBARK_COST_DESCRIPTION">
