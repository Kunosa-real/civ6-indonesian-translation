		</Row>
		<Row Tag="LOC_DIPLO_DENOUNCE_REASON_FROM_AI_LEADER_ANY_REASON_AGENDA_HIGH_TOURISM">
			<Text>(Pariwisata Anda terlalu tinggi.)</Text>
		</Row>
		<Row Tag="LOC_DIPLO_DENOUNCE_REASON_FROM_AI_LEADER_ANY_REASON_AGENDA_LOW_PILLAGE">
			<Text>(Anda belum cukup menjarah ubin.)</Text>
		</Row>
		<Row Tag="LOC_DIPLO_DENOUNCE_REASON_FROM_AI_LEADER_ANY_REASON_AGENDA_FLAT_EARTHER">
